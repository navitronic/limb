---
layout: default
---
<h1>Welcome to {{ site.title }}</h1>
{{ content|raw }}

<h2>Latest Posts</h2>
<ul>
{% for post in site.posts %}
    <li>
        <a href="{{ post.url }}">{{ post.title }}</a>
        <time datetime="{{ post.date|date('Y-m-d') }}">{{ post.date|date_to_string }}</time>
    </li>
{% endfor %}
</ul>
